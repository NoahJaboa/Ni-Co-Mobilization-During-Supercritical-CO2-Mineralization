#=========================== output options ===================================
OUTPUT
  SNAPSHOT_FILE
    TIMES y 1.d-2 1.d-1 1.d0
    PERIODIC TIME 1.d0 y
    FORMAT HDF5
  /
  UNFILTER_NON_STATE_VARIABLES

  VARIABLES
   TEMPERATURE
   LIQUID_PRESSURE
   GAS_PRESSURE
   LIQUID_SATURATION
   GAS_SATURATION
   PRECIPITATE_SATURATION
   TRAPPED_GAS_SATURATION
   LIQUID_MASS_FRACTIONS
   GAS_MASS_FRACTIONS
   GAS_DENSITY
   PERMEABILITY
   LIQUID_RELATIVE_PERMEABILITY
   GAS_RELATIVE_PERMEABILITY
   POROSITY
   VOLUME
   THERMODYNAMIC_STATE
  /
END

#=========================== times ============================================
TIME
  FINAL_TIME 1.d1 y
  INITIAL_TIMESTEP_SIZE 1.d-5 y
  MAXIMUM_TIMESTEP_SIZE 5.d-1 y
END


#=========================== regions ==========================================
REGION all
  COORDINATES
    0.d0    0.d0 -1157.935d0
    3048.d0 1.d0 -965.9112d0
  /
END

REGION edge
  FACE EAST
  COORDINATES
    3048.d0 0.d0  -1157.935d0
    3048.d0 1.d0  -965.9112d0
  /
END

REGION injection
  COORDINATES
   0.0d0 0.d0 -1157.935d0
   0.0d0 0.d0 -981.1512d0
  /
END

REGION caprock
  BLOCK 1 20 1 1 25 25
END

