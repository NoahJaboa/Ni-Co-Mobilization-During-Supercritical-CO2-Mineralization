SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE SCO2
      OPTIONS
        ISOTHERMAL_TEMPERATURE 37.d0
        NO_STATE_TRANSITION_OUTPUT
      /
    /
  /
END

SUBSURFACE

NUMERICAL_METHODS flow

  NEWTON_SOLVER
    USE_INFINITY_NORM_CONVERGENCE
    NUMERICAL_JACOBIAN
    MINIMUM_NEWTON_ITERATIONS 2
  END

  TIMESTEPPER FLOW
    TIMESTEP_MAXIMUM_GROWTH_FACTOR 1.25
  END

END

#=========================== discretization ===================================
GRID
  TYPE STRUCTURED CARTESIAN
  NXYZ 100 1 78
  DXYZ  
    2, 2.1, 2.2, 2.3, 2.5, \
    2.6, 2.7, 2.8, 3, 3.2, 3.3,\
    3.5, 3.6, 3.9, 4.1,	4.2, 4.5,\
    4.7, 5.0, 5.2, 5.5, 5.8, 6.1,\
    6.4, 6.7, 7.1, 7.4, 7.8, 8.3,\
    8.6, 9.1, 9.6, 10.1, 10.6, 11.1\
    11.8, 12.3, 13.0, 13.6, 14.4, 15.1\
    15.8, 16.7, 17.6, 18.5, 19.4, 20.5\
    21.5, 22.6, 23.8, 25, 26.3, 27.7\
    29.1, 30.6, 32.2, 33.9, 35.7, 37.5\
    39.4, 41.5, 43.6, 45.9, 48.2, 50.8\
    53.4, 56.1,	59.1, 62.1, 65.4, 68.7\
    72.3, 76.1,	80, 84.1, 88.5, 93.1\
    97.9, 103, 108.3, 114, 119.8, 126.1\
    132.6, 139.4, 146.7, 154.3, 162.3, 170.7\
    179.6, 188.8, 198.7, 208.9, 219.8, 231.1,\
    243.2, 255.7, 269, 283, 296.6

    1@1.d0

    7@3.d0, 1@2.d0, 9@3.d0, 1@2.d0, 3@1.d0,\
    1@1.d0, 1@2.d0, 8@3.d0, 1@2.d0, 1@1.d0, 3@1.d0,\
    1@1.d0, 1@2.d0, 8@3.d0, 1@2.d0, 1@1.d0, 3@1.d0,\
    1@1.d0, 1@2.d0, 8@3.d0, 1@2.d0, 1@1.d0, 3@1.d0,\
    1@1.d0, 1@2.d0, 8@3.d0, 1@2.d0, 1@1.d0
  /
END

#=========================== fluid properties =================================
FLUID_PROPERTY
  PHASE LIQUID
  DIFFUSION_COEFFICIENT 2.d-9
END

FLUID_PROPERTY
  PHASE GAS
  DIFFUSION_COEFFICIENT 2.d-5
END

#=========================== more fluid properties ============================
EOS WATER
  DENSITY IF97
  ENTHALPY IF97
  STEAM_DENSITY IF97
  STEAM_ENTHALPY IF97
  SATURATION_PRESSURE IF97
END

EOS GAS
  CO2_DATABASE ../../co2_sw.dat
  HENRYS_CONSTANT DEFAULT
END


#=========================== material properties ==============================
MATERIAL_PROPERTY sand
  ID 1
  CHARACTERISTIC_CURVES sand
  POROSITY 0.35
  TORTUOSITY 1.d0
  ROCK_DENSITY 2650.d0
  THERMAL_CONDUCTIVITY_DRY 2.d0
  THERMAL_CONDUCTIVITY_WET 2.18d0
  HEAT_CAPACITY 1000 J/kg-C
  PERMEABILITY
    PERM_ISO 3.d-12
  /
  SOIL_COMPRESSIBILITY_FUNCTION LINEAR
  SOIL_COMPRESSIBILITY 4.5d-10
  SOIL_REFERENCE_PRESSURE 1.d7
END

MATERIAL_PROPERTY shale
  ID 2
  CHARACTERISTIC_CURVES shale
  POROSITY 0.1025
  TORTUOSITY 1.d0
  ROCK_DENSITY 2650.d0
  THERMAL_CONDUCTIVITY_DRY 2.d0
  THERMAL_CONDUCTIVITY_WET 2.18d0
  HEAT_CAPACITY 1000 J/kg-C
  PERMEABILITY
    PERM_ISO 1.d-14
  /
  SOIL_COMPRESSIBILITY_FUNCTION LINEAR
  SOIL_COMPRESSIBILITY 4.5d-10
  SOIL_REFERENCE_PRESSURE 1.d7
END

#=========================== characteristic curves ============================

CHARACTERISTIC_CURVES sand
SATURATION_FUNCTION VG_STOMP
    ALPHA 2.735 # for head function
    N 1.667
    OVEN_DRIED_CAP_HEAD 102108.2d0
    LIQUID_RESIDUAL_SATURATION 0.2d0
    MAX_TRAPPED_GAS_SAT 0.d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_LIQ
    SMOOTH
    PHASE LIQUID
    M 0.4
    LIQUID_RESIDUAL_SATURATION 0.2
  /
  PERMEABILITY_FUNCTION MODIFIED_COREY_GAS
    PHASE GAS
    LIQUID_RESIDUAL_SATURATION 0.2
    GAS_RESIDUAL_SATURATION 0.05
  /
END

CHARACTERISTIC_CURVES shale
  SATURATION_FUNCTION VG_STOMP
    ALPHA 0.158
    N 1.667
    LIQUID_RESIDUAL_SATURATION 0.2d0
    OVEN_DRIED_CAP_HEAD 102108.2d0
    MAX_TRAPPED_GAS_SAT 0.d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_LIQ
    SMOOTH
    PHASE LIQUID
    M 0.4
    LIQUID_RESIDUAL_SATURATION 0.2
  /
  PERMEABILITY_FUNCTION MODIFIED_COREY_GAS
    PHASE GAS
    LIQUID_RESIDUAL_SATURATION 0.2
    GAS_RESIDUAL_SATURATION 0.05
  /
END


#=========================== output options ===================================
OUTPUT
  SNAPSHOT_FILE
    TIMES y 1.d-2 1.d-1 1.d0 1.1d0 1.2d0 1.3d0 1.4d0 1.5d0 1.6d0 1.7d0 1.8d0 1.9d0 2.d0
    TIMES d 30
    FORMAT HDF5
  /
  UNFILTER_NON_STATE_VARIABLES
  
  VARIABLES
   TEMPERATURE
   LIQUID_PRESSURE
   GAS_PRESSURE
   LIQUID_SATURATION
   GAS_SATURATION
   PRECIPITATE_SATURATION
   LIQUID_MASS_FRACTIONS
   GAS_MASS_FRACTIONS
   GAS_DENSITY
   PERMEABILITY
   LIQUID_RELATIVE_PERMEABILITY
   GAS_RELATIVE_PERMEABILITY
   POROSITY
  /
END

#=========================== times ============================================
TIME
  FINAL_TIME 2 y
  INITIAL_TIMESTEP_SIZE 1.d0 s 
  MAXIMUM_TIMESTEP_SIZE 1.d-1 y  
END


#=========================== regions ==========================================
REGION all
  COORDINATES
    0.d0 0.d0 0.d0
    1.d5 1.d5 1.d5
  /
END

REGION east
  FACE EAST
  COORDINATES
    6.d3 0.d0 0.d0
    6.d3 1.d0 184.d0
  /
END

REGION shale1
  COORDINATES
    0.d0 0.d0 52.d0
    6.d3 1.d0 55.d0
  /
END

REGION shale2
  COORDINATES
    0.d0 0.d0 85.d0
    6.d3 1.d0 88.d0
  /
END

REGION shale3
  COORDINATES
    0.d0 0.d0 118.d0
    6.d3 1.d0 121.d0
  /
END

REGION shale4
  COORDINATES
    0.d0 0.d0 151.d0
    6.d3 1.d0 154.d0
  /
END


REGION well
  COORDINATE 1.d0 1.d0 22.d0
END

#=========================== flow conditions ==================================

FLOW_CONDITION initial
  TYPE
    LIQUID_PRESSURE HYDROSTATIC
    CO2_MASS_FRACTION DIRICHLET
    SALT_MASS_FRACTION DIRICHLET
  /
  DATUM 0.d0 0.d0 22.d0
  LIQUID_PRESSURE 1.120525d7
  CO2_MASS_FRACTION 0.d0 
  SALT_MASS_FRACTION 0.032d0
END

FLOW_CONDITION well
  SYNC_TIMESTEP_WITH_UPDATE
  TYPE
    RATE MASS_RATE
  /
  RATE 0.d0 1.585d-1 0.d0 kg/s kg/s kg/s
END



#=========================== condition couplers ===============================
# initial condition
INITIAL_CONDITION all
  FLOW_CONDITION initial
  REGION all
END

BOUNDARY_CONDITION east
  FLOW_CONDITION initial
  REGION east
END

SOURCE_SINK well
  FLOW_CONDITION well
  REGION well
END



#=========================== stratigraphy couplers ============================
STRATA
  REGION all
  MATERIAL sand
END

STRATA
  REGION shale1
  MATERIAL shale
END

STRATA
  REGION shale2
  MATERIAL shale
END

STRATA
  REGION shale3
  MATERIAL shale
END

STRATA
  REGION shale4
  MATERIAL shale
END


#=========================== convergence criteria  ============================
END_SUBSURFACE
