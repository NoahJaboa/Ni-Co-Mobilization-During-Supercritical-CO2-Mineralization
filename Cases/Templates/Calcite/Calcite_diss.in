# =============================================================================
# 2D PFLOTRAN MODEL:
# CLOSED BOUNDARIES + LEFT CO2 INJECTION + FAR-RIGHT BRINE PRODUCTION
# =============================================================================

SIMULATION
  SIMULATION_TYPE SUBSURFACE

  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE SCO2
      OPTIONS
        NO_STATE_TRANSITION_OUTPUT
        FIXED_TEMPERATURE_GRADIENT
      /
    /

    SUBSURFACE_TRANSPORT transport
      MODE GIRT
      OPTIONS
        REACTION_TEMPERATURE_DEPENDENCE ISOTHERMAL
        REFERENCE_TEMPERATURE 25.d0
      /
    /
  /
END

SUBSURFACE

CO2_DATABASE ./co2_sw.dat

NUMERICAL_METHODS flow
  NEWTON_SOLVER
    USE_INFINITY_NORM_CONVERGENCE
    NUMERICAL_JACOBIAN
    MINIMUM_NEWTON_ITERATIONS 2
  END

  TIMESTEPPER FLOW
    PRESSURE_CHANGE_GOVERNOR 1.d8
    TIMESTEP_MAXIMUM_GROWTH_FACTOR 1.10
  END
END

NUMERICAL_METHODS TRANSPORT
  TIMESTEPPER
    TS_ACCELERATION 16
  /
END

CHEMISTRY
  PRIMARY_SPECIES
    H+
    Ca++
    HCO3-
    Na+
    Cl-
  /

  SECONDARY_SPECIES
    OH-
    CO3--
    CO2(aq)
    CaOH+
    CaHCO3+
    CaCO3(aq)
  /

  PASSIVE_GAS_SPECIES
    CO2(g)
  /

  MINERALS
    Calcite
  /

  MINERAL_KINETICS
    Calcite
      RATE_CONSTANT 1.d-10 mol/cm^2-sec
    /
  /

  DATABASE ./hanford.dat
  LOG_FORMULATION
  ACTIVITY_COEFFICIENTS TIMESTEP

  OUTPUT
    PH
    TOTAL
    ALL
  /

  DECOUPLE_CO2
END

GRID
  TYPE STRUCTURED
  NXYZ 200 1 60
  BOUNDS
    0.d0   0.d0  -60.d0
    200.d0 1.d0    0.d0
  /
END

FLUID_PROPERTY
  PHASE LIQUID
  DIFFUSION_COEFFICIENT 1.d-9
END

FLUID_PROPERTY
  PHASE GAS
  DIFFUSION_COEFFICIENT 2.d-5
END

EOS WATER
  DENSITY IF97
  ENTHALPY IF97
  STEAM_DENSITY IF97
  STEAM_ENTHALPY IF97
  SATURATION_PRESSURE IF97
END

EOS GAS
  CO2_DATABASE ./co2_sw.dat
  HENRYS_CONSTANT DEFAULT
END

MATERIAL_PROPERTY reservoir
  ID 1
  CHARACTERISTIC_CURVES reservoir_cc

  POROSITY 0.20d0
  TORTUOSITY 1.d0
  ROCK_DENSITY 2650.d0

  PERMEABILITY
    PERM_X 1.d-13
    PERM_Y 1.d-13
    PERM_Z 1.d-14
  /

  THERMAL_CONDUCTIVITY_DRY 0.5d0
  THERMAL_CONDUCTIVITY_WET 2.0d0
  HEAT_CAPACITY 830.d0

  SOIL_COMPRESSIBILITY_FUNCTION LINEAR
  POROSITY_COMPRESSIBILITY 1.d-8
  SOIL_REFERENCE_PRESSURE INITIAL_PRESSURE
END

CHARACTERISTIC_CURVES reservoir_cc
  SATURATION_FUNCTION BROOKS_COREY
    SMOOTH
    ALPHA 6.496104d-5
    LAMBDA 4.033d0
    LIQUID_RESIDUAL_SATURATION 0.05d0
    MAX_CAPILLARY_PRESSURE 1.d10
  /

  PERMEABILITY_FUNCTION BURDINE_BC_LIQ
    PHASE LIQUID
    LAMBDA 4.033d0
    LIQUID_RESIDUAL_SATURATION 0.05d0
  /

  PERMEABILITY_FUNCTION MODIFIED_COREY_GAS
    PHASE GAS
    LIQUID_RESIDUAL_SATURATION 0.05d0
    GAS_RESIDUAL_SATURATION 0.d0
  /
END


OUTPUT
  SNAPSHOT_FILE
    TIMES y 1.d-4 1.d-3 1.d-2 1.d-1 5.d-1 1.d0 2.d0 3.d0 4.d0 5.d0
    PERIODIC TIME 0.1 y
    FORMAT HDF5
  /

  MASS_BALANCE_FILE
    PERIODIC TIMESTEP 1
    TOTAL_MASS_REGIONS
      all
    /
  /

  UNFILTER_NON_STATE_VARIABLES

  VARIABLES
    TEMPERATURE
    LIQUID_PRESSURE
    GAS_PRESSURE
    LIQUID_SATURATION
    GAS_SATURATION
    LIQUID_MASS_FRACTIONS
    GAS_MASS_FRACTIONS
    LIQUID_DENSITY
    GAS_DENSITY
    PERMEABILITY
    LIQUID_RELATIVE_PERMEABILITY
    GAS_RELATIVE_PERMEABILITY
    POROSITY
    VOLUME
  /
END

TIME
  FINAL_TIME 5.d0 y
  INITIAL_TIMESTEP_SIZE 1.d-5 y
  MAXIMUM_TIMESTEP_SIZE 1.d-2 y
END

REGION all
  COORDINATES
    -1.d20 -1.d20 -1.d20
     1.d20  1.d20  1.d20
  /
END

REGION injection_zone
  COORDINATES
    0.d0 0.d0 -60.d0
    2.d0 1.d0   0.d0
  /
END

REGION production_zone
  COORDINATES
    198.d0 0.d0 -60.d0
    200.d0 1.d0   0.d0
  /
END

REGION top
  FACE TOP
  COORDINATES
    0.d0   0.d0 0.d0
    200.d0 1.d0 0.d0
  /
END

REGION bottom
  FACE BOTTOM
  COORDINATES
    0.d0   0.d0 -60.d0
    200.d0 1.d0 -60.d0
  /
END

REGION east
  FACE EAST
  COORDINATES
    200.d0 0.d0 -60.d0
    200.d0 1.d0   0.d0
  /
END

REGION west
  FACE WEST
  COORDINATES
    0.d0 0.d0 -60.d0
    0.d0 1.d0   0.d0
  /
END

FLOW_CONDITION initial
  TYPE
    LIQUID_PRESSURE HYDROSTATIC
    CO2_MASS_FRACTION DIRICHLET
    SALT_MASS_FRACTION DIRICHLET
    TEMPERATURE DIRICHLET
  /

  DATUM 0.d0 0.d0 0.d0
  LIQUID_PRESSURE 8.3d6
  CO2_MASS_FRACTION 0.d0
  SALT_MASS_FRACTION 1.d-2
  TEMPERATURE 40.d0
END

FLOW_CONDITION co2_rate_injection
  TYPE
    RATE MASS_RATE
  /

  RATE LIST
    TIME_UNITS y
    DATA_UNITS kg/s kg/s kg/s MW
    0.d0        1.d-4  0.d0  0.d0  0.d0
    2.d0        1.d-4  0.d0  0.d0  0.d0
    2.000001d0  0.d0   0.d0  0.d0  0.d0
    5.d0        0.d0   0.d0  0.d0  0.d0
  /
END

FLOW_CONDITION brine_production
  TYPE
    RATE MASS_RATE
  /

  RATE LIST
    TIME_UNITS y
    DATA_UNITS kg/s kg/s kg/s MW
    0.d0   0.d0     0.d0  0.d0  0.d0
    2.d0   0.d0     0.d0  0.d0  0.d0
    2.5d0 -1.d-6   0.d0  0.d0  0.d0
    3.5d0 -5.d-6   0.d0  0.d0  0.d0
    5.d0  -5.d-6   0.d0  0.d0  0.d0
  /
END

TRANSPORT_CONDITION initial
  TYPE ZERO_GRADIENT
  CONSTRAINT_LIST
    0.d0 initial
  /
END

TRANSPORT_CONDITION injection
  TYPE DIRICHLET_ZERO_GRADIENT
  CONSTRAINT_LIST
    0.d0 injection
  /
END

TRANSPORT_CONDITION production
  TYPE ZERO_GRADIENT
  CONSTRAINT_LIST
    0.d0 initial
  /
END

CONSTRAINT initial
  CONCENTRATIONS
    H+       7.d0     P
    Ca++     1.d-3    T
    HCO3-   -3.d0     G CO2(g)
    Na+      1.d-2    T
    Cl-      1.d-2    Z
  /

  MINERALS
    Calcite  0.20d0  1.d0 cm^2/cm^3
  /
END

CONSTRAINT injection
  CONCENTRATIONS
    H+       3.d0     P
    Ca++     1.d-6    T
    HCO3-   -2.d0     G CO2(g)
    Na+      1.d-2    T
    Cl-      1.d-2    Z
  /
END

INITIAL_CONDITION
  FLOW_CONDITION initial
  TRANSPORT_CONDITION initial
  REGION all
END

SOURCE_SINK co2_source
  FLOW_CONDITION co2_rate_injection
  TRANSPORT_CONDITION injection
  REGION injection_zone
END

SOURCE_SINK brine_sink
  FLOW_CONDITION brine_production
  TRANSPORT_CONDITION production
  REGION production_zone
END

STRATA
  REGION all
  MATERIAL reservoir
END

END_SUBSURFACE